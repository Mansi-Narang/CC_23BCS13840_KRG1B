// find whether topo sort is possible or not
#include <bits/stdc++.h>
using namespace std;


int main(){
    int n;
    cin >> n;
    int m;
    cin >> m;
    vector<vector<int>>edges;

    for(int i = 0; i < m; i++){
        int u, v;
        cin >> u >> v;

        edges.push_back({u,v});
    }

    vector<vector<int>>adj(n);
    vector<int>indegree(n, 0);
    for(auto it : edges){
        adj[it[0]].push_back(it[1]);
        indegree[it[1]]++;
    }

    queue<int>q;
    for(int i = 0; i < n; i++){
        if(indegree[i] == 0){
            q.push(i);
        }
    }
    int cnt = 0;
    while(!q.empty()){
        int node = q.front(); q.pop();
        cnt++;
        for(auto it : adj[node]){
            indegree[it]--;
            if(indegree[it] == 0) q.push(it);
        }
    }

    if(cnt == n) cout << "TRUE";
    else cout <<"FALSE";

    return 0;
}
